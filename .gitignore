# Build
target/
rust_out

# Node
node_modules/
apps/admin-console/node_modules/
apps/admin-console/dist/
apps/admin-console/.vite/
apps/*/node_modules/
apps/*/dist/
apps/*/.vite/
apps/*/.astro/
packages/*/node_modules/
packages/*/dist/
e2e/node_modules/
examples/ai-sdk-starter/node_modules/
examples/ai-sdk-starter/dist/
examples/copilotkit-starter/node_modules/
examples/copilotkit-starter/.next/
examples/copilotkit-starter/sessions/
examples/copilotkit-starter/tsconfig.tsbuildinfo
examples/copilotkit-starter/test-results/
examples/openui-chat/node_modules/
examples/openui-chat/dist/
e2e/test-results/

# Python
__pycache__/

# Tools
.claude/
.playwright-mcp/
.sigdiff/
.worktrees/

# Sessions / runtime data
sessions/
# ...except the rubix backend build-loop orchestration docs (the loop's own
# runtime artifacts are ignored by rubix/docs/sessions/.gitignore).
!rubix/docs/sessions/
!rubix/docs/sessions/**
# ...and the NHP POC build-loop orchestration docs (its runtime artifacts —
# .loop.lock/.heartbeat/.STOP/cron.log — are ignored by nhp/docs/sessions/.gitignore).
!nhp/docs/sessions/
!nhp/docs/sessions/**

# Docs (generated by mdbook-mermaid install)
docs/book/mermaid.min.js
docs/book/mermaid-init.js

# Screenshots
*.png
# ...except checked-in documentation assets.
!docs/assets/**/*.png
# ...and docs-site copies served from Astro public/.
!apps/www/public/assets/admin-console/**/*.png
# ...and Playwright visual-regression baselines (one per surface × theme × locale).
!e2e/tests/**/*-snapshots/**/*.png
# ...and the rubix UI look-freeze reference captures (docs/sessions/ui/UI-02.md).
!rubix/ui/docs/reference/**/*.png
coverage_err.log
.dev/
# Design-reference repos kept on disk only (e.g. flow-like) — never committed.
bin/
