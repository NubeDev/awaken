VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the rubix-server records API (default: same origin, '').
VITE_API_BASE=

# Service-account credentials for the rubix records API against a --seed-dev
# backend (the seeded acme operator from WS-02/03). Used only when no Bearer
# token is set on the sign-in screen. See nhp/ui/src/api/client.ts.
VITE_RUBIX_SUBJECT=acme_operator
VITE_RUBIX_SECRET=operator-demo

# Admin credential for the rubix PRINCIPAL surface (/principals), used by the
# Users admin (WS-05). Those routes require Role::Admin, which the operator above
# is NOT — so user CRUD authenticates as a namespace admin. Defaults to the seeded
# acme_admin / admin-demo (rubix --seed-dev cast). See nhp/ui/src/api/admin.ts.
VITE_RUBIX_ADMIN_SUBJECT=acme_admin
VITE_RUBIX_ADMIN_SECRET=admin-demo
